services:
  pg_primary:
    image: postgres:15
    container_name: pg_primary
    environment:
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: password123
      POSTGRES_DB: mercately_db
    ports:
      - "5432:5432"
    command: >
      postgres 
      -c wal_level=logical 
      -c max_replication_slots=10 
      -c max_wal_senders=10
    networks:
      - pg_network

  pg_reporting:
    image: postgres:15
    container_name: pg_reporting
    environment:
      POSTGRES_USER: admin_report
      POSTGRES_PASSWORD: password_report
      POSTGRES_DB: reporting_db
    ports:
      - "5433:5432"
    depends_on:
      - pg_primary
    networks:
      - pg_network

networks:
  pg_network:
    driver: bridge
